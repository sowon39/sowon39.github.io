{
  "meta": {
    "version": "2026-03-04.benchdips.final1.hammercurl.opt4.latraise_unified",
    "appName": "DK Fit",
    "lang": "ko"
  },
  "data": {
    "workout": {
      "1": {
        "day": "월요일",
        "type": "push",
        "title": "가슴 & 삼두 (Safe Strength)",
        "list": [
          {
            "name": "덤벨 벤치프레스",
            "set": 4,
            "rep": 8,
            "rest": 90,
            "breath": "내려가며 흡기 / 밀며 호기",
            "target": "가슴 두께 & 삼두",
            "mind": "견갑 고정하고 가슴으로 밀어낸다",
            "tip": "HOW\n1) 견갑 후인/하강(가슴 열기)\n2) 팔꿈치 45도\n3) 하강 2초\n4) 상단 1초 수축",
            "guide": "UPGRADE\n- 8회가 쉬우면 +1~2kg 또는 10~12회",
            "cue": "견갑 고정 + 가슴 프레스"
          },
          {
            "name": "덤벨 플라이",
            "set": 3,
            "rep": 12,
            "rest": 75,
            "breath": "내려가며 흡기 / 모으며 호기",
            "target": "가슴 전체(스트레치)",
            "mind": "가슴을 길게 늘렸다가 모아준다",
            "tip": "HOW\n1) 팔꿈치 살짝 굽힘 유지\n2) 가슴이 늘어나는 지점까지만\n3) 상단에서 가슴 조이기 1초",
            "guide": "CHECK\n- 어깨 통증 나면 가동범위 줄이기",
            "cue": "가슴 늘리고 모아라"
          },
          {
            "name": "스탠다드 푸쉬업",
            "set": 3,
            "rep": 15,
            "rest": 60,
            "breath": "내려가며 흡기 / 밀며 호기",
            "target": "가슴 펌핑",
            "mind": "마무리 펌핑. 개수 줄어도 정상",
            "tip": "HOW\n1) 몸 일직선 유지\n2) 가슴 바닥 직전까지 하강\n3) 상단에서 가슴 수축",
            "guide": "POINT\n- 앞 운동(벤치/플라이) 후에는 15회를 못 채워도 정상. 폼 유지 가능한 만큼 수행하세요.",
            "cue": "몸 일직선 + 가슴 수축"
          },
          {
            "name": "벤치 딥스",
            "set": 3,
            "rep": 12,
            "rest": 75,
            "breath": "밀 때 호기",
            "target": "삼두 중심",
            "mind": "어깨 말리지 않게, 삼두로 밀어낸다",
            "tip": "HOW\n1) 손은 엉덩이 옆/뒤, 가슴 펴기\n2) 상체 10~20도 살짝 숙여도 OK\n3) 팔꿈치 뒤로, 깊이는 팔꿈치 90도까지만\n4) 위에서 완전히 잠그지 말고 95%만",
            "guide": "SAFETY\n- 어깨 앞쪽 통증 있으면 즉시 깊이 줄이거나 중단. 견갑(어깨) 내리고 가슴 열기 유지.",
            "cue": "90도까지만 + 어깨 내리기"
          },
          {
            "name": "덤벨 오버헤드 트라이셉스 익스텐션",
            "set": 3,
            "rep": 10,
            "rest": 60,
            "breath": "올리며 호기 / 내리며 흡기",
            "target": "삼두 장두",
            "mind": "팔꿈치 고정, 삼두로만 펴라",
            "tip": "HOW\n1) 덤벨 1개를 양손으로\n2) 팔꿈치 좁게 고정\n3) 2~3초 하강\n4) 정점 1초 수축",
            "guide": "CHECK\n- 어깨가 아프면 가동범위 줄이고 팔꿈치 더 좁게",
            "cue": "팔꿈치 고정 + 3초 하강"
          }
        ]
      },

      "2": {
        "day": "화요일",
        "type": "pull",
        "title": "등 두께 + 이두 (Thickness)",
        "list": [
          {
            "name": "풀업 (밴드)",
            "set": 4,
            "rep": 8,
            "rest": 120,
            "breath": "당길 때 호기",
            "target": "광배 바깥",
            "mind": "숄더패킹 유지",
            "tip": "HOW\n1) 숄더패킹\n2) 팔꿈치 아래로 찍기\n3) 하강 2초",
            "guide": "UPGRADE\n- 밴드 점진 제거",
            "cue": "팔꿈치 아래로"
          },
          {
            "name": "덤벨 로우",
            "set": 4,
            "rep": 12,
            "rest": 90,
            "breath": "당길 때 호기",
            "target": "등 중앙",
            "mind": "광배를 접고 날개뼈를 모은다",
            "tip": "HOW\n1) 상체 30~45도 고정\n2) 팔꿈치 뒤로 길게\n3) 정점 1초\n4) 하강 2초",
            "guide": "POINT\n- 반동 금지",
            "cue": "팔꿈치 뒤로"
          },
          {
            "name": "친업 (밴드)",
            "set": 3,
            "rep": 8,
            "rest": 90,
            "breath": "올라갈 때 호기",
            "target": "등 하부 & 이두",
            "mind": "가슴을 봉으로",
            "tip": "HOW\n1) 언더그립\n2) 가슴을 봉으로\n3) 하강 컨트롤",
            "guide": "CHECK\n- 턱만 넘기지 말 것",
            "cue": "가슴 봉 접근"
          },
          {
            "name": "덤벨 해머 컬",
            "set": 4,
            "rep": 10,
            "rest": 60,
            "breath": "올리며 호기 / 내리며 흡기",
            "target": "팔 두께(상완근/전완) + 이두",
            "mind": "반동 없이 팔 두께를 만든다",
            "tip": "HOW\n1) 손바닥 서로 마주보기(중립)\n2) 팔꿈치 몸통 옆 고정\n3) 정점 1초 수축\n4) 내려갈 때 3초",
            "guide": "UPGRADE\n- 10회 쉬우면 +1~2kg 또는 12~15회",
            "cue": "중립그립 + 3초 하강"
          }
        ]
      },

      "3": {
        "day": "수요일",
        "type": "leg",
        "title": "하체 + 측면 어깨 (Foundation+Load)",
        "list": [
          {
            "name": "덤벨 고블릿 스쿼트",
            "set": 5,
            "rep": 12,
            "rest": 90,
            "breath": "내려가며 흡기 / 밀며 호기",
            "target": "허벅지/둔근",
            "mind": "덤벨로 하체에 부하를 건다",
            "tip": "HOW\n1) 덤벨을 가슴 앞에 고정\n2) 무릎은 발끝 방향\n3) 바닥을 밀며 올라오기\n4) 하강 2초",
            "guide": "UPGRADE\n- 12회 쉬우면 +무게 또는 +1세트",
            "cue": "가슴 들고 깊게"
          },
          {
            "name": "런지",
            "set": 4,
            "rep": 12,
            "rest": 60,
            "breath": "올라오며 호기",
            "target": "엉덩이",
            "mind": "뒤꿈치 80%",
            "tip": "HOW\n1) 상체 살짝 숙임\n2) 수직 하강\n3) 뒤꿈치로 밀기",
            "guide": "POINT\n- 무릎 방향 주의",
            "cue": "뒤꿈치 밀기"
          },
          {
            "name": "덤벨 레터럴 레이즈",
            "set": 5,
            "rep": 20,
            "rest": 60,
            "breath": "올릴 때 호기",
            "target": "측면 삼각근",
            "mind": "팔꿈치를 던진다",
            "tip": "HOW\n1) 승모 억제\n2) 옆으로 멀리\n3) 저항 하강",
            "guide": "UPGRADE\n- 고반복 펌핑",
            "cue": "옆으로 던져라"
          }
        ]
      },

      "4": {
        "day": "목요일",
        "type": "push",
        "title": "어깨 + 상부가슴 + 삼두 (Safe Volume)",
        "list": [
          {
            "name": "파이크 푸쉬업",
            "set": 4,
            "rep": 10,
            "rest": 90,
            "breath": "밀 때 호기",
            "target": "전면 어깨",
            "mind": "수직 프레스",
            "tip": "HOW\n1) 역V자\n2) 정수리 하강\n3) 어깨로 밀기",
            "guide": "MISTAKE\n- 팔꿈치 벌어짐 주의",
            "cue": "어깨로 밀어라"
          },
          {
            "name": "디클라인 푸쉬업",
            "set": 3,
            "rep": 12,
            "rest": 90,
            "breath": "밀 때 호기",
            "target": "상부 가슴",
            "mind": "윗가슴 펌핑. 개수 줄어도 정상",
            "tip": "HOW\n1) 발 높임\n2) 몸 일직선\n3) 윗가슴 수축",
            "guide": "POINT\n- 12회를 못 채워도 정상. 폼 유지 가능한 만큼 수행하세요.",
            "cue": "윗가슴으로 밀어라"
          },
          {
            "name": "벤치 딥스",
            "set": 3,
            "rep": 12,
            "rest": 75,
            "breath": "밀 때 호기",
            "target": "삼두",
            "mind": "어깨 보호가 우선",
            "tip": "HOW\n1) 견갑 내리고 가슴 열기\n2) 팔꿈치 90도까지만\n3) 위에서 95%만 펴기",
            "guide": "SAFETY\n- 어깨 앞쪽 불편하면 깊이를 즉시 줄이세요.",
            "cue": "90도까지만"
          }
        ]
      },

      "5": {
        "day": "금요일",
        "type": "pull",
        "title": "등 넓이 + 어깨 (Width+Delts)",
        "list": [
          {
            "name": "와이드 풀업",
            "set": 4,
            "rep": 6,
            "rest": 120,
            "breath": "올라갈 때 호기",
            "target": "광배 외곽",
            "mind": "등 펼치기",
            "tip": "HOW\n1) 넓은 그립\n2) 팔꿈치 하강",
            "guide": "CHECK\n- 반동 금지",
            "cue": "등 펼치기"
          },
          {
            "name": "덤벨 로우",
            "set": 4,
            "rep": 12,
            "rest": 90,
            "breath": "당길 때 호기",
            "target": "등 전체",
            "mind": "광배를 접는다",
            "tip": "HOW\n1) 가슴 펴기\n2) 팔꿈치 뒤로\n3) 정점 1초",
            "guide": "POINT\n- 등 수축 집중",
            "cue": "팔꿈치 뒤로"
          },
          {
            "name": "덤벨 해머 컬",
            "set": 3,
            "rep": 12,
            "rest": 60,
            "breath": "올리며 호기 / 내리며 흡기",
            "target": "팔 두께(상완근/전완) + 이두",
            "mind": "3초 하강",
            "tip": "HOW\n1) 중립그립\n2) 팔꿈치 고정\n3) 3초 하강",
            "guide": "POINT\n- 팔 두께 마무리",
            "cue": "천천히 내려라"
          },
          {
            "name": "덤벨 레터럴 레이즈",
            "set": 3,
            "rep": 20,
            "rest": 45,
            "breath": "올릴 때 호기 / 내릴 때 흡기",
            "target": "측면 삼각근",
            "mind": "승모 빼고 팔꿈치 리드",
            "tip": "HOW\n1) 덤벨 가볍게\n2) 정점 1초\n3) 2초 하강",
            "guide": "UPGRADE\n- 어깨 폭은 주 2회가 빠르다",
            "cue": "팔꿈치로 들어라"
          }
        ]
      },

      "6": {
        "day": "토요일",
        "type": "leg",
        "title": "하체 & 코어 (Conditioning+Hinge)",
        "list": [
          {
            "name": "덤벨 루마니안 데드리프트",
            "set": 4,
            "rep": 12,
            "rest": 75,
            "breath": "내려가며 흡기 / 올라오며 호기",
            "target": "햄스트링/둔근/하체 후면",
            "mind": "엉덩이를 뒤로 빼며 힙힌지",
            "tip": "HOW\n1) 무릎 살짝 굽힘\n2) 엉덩이 뒤로\n3) 허리 중립\n4) 햄스트링 늘어나는 지점까지만",
            "guide": "POINT\n- 하체 라인/힙업 핵심",
            "cue": "엉덩이 뒤로 + 허리 중립"
          },
          {
            "name": "런지",
            "set": 3,
            "rep": 15,
            "rest": 60,
            "breath": "올라오며 호기",
            "target": "하체",
            "mind": "버티기",
            "tip": "HOW\n1) 균형 유지",
            "guide": "CHECK\n- 코어 흔들림",
            "cue": "둔근 조이기"
          },
          {
            "name": "플랭크",
            "set": 3,
            "rep": 60,
            "rest": 60,
            "breath": "짧고 일정",
            "target": "전신 코어",
            "mind": "판자",
            "tip": "HOW\n1) 배 당김",
            "guide": "MISTAKE\n- 허리 꺾임",
            "cue": "강철 일직선"
          }
        ]
      }
    },


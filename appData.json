    "workout": {
      "1": {
        "day": "월요일",
        "type": "push",
        "title": "가슴 & 삼두 (Strength)",
        "list": [
          {
            "name": "덤벨 벤치프레스",
            "set": 4,
            "rep": 8,
            "rest": 90,
            "breath": "내려가며 흡기 / 밀며 호기",
            "target": "가슴 전체",
            "mind": "견갑을 고정하고 가슴으로 밀어낸다",
            "tip": "HOW\n1) 견갑 후인\n2) 팔꿈치 45도\n3) 천천히 하강\n4) 가슴 수축",
            "guide": "UPGRADE\n- 가슴 두께 핵심 운동",
            "cue": "가슴으로 밀어라"
          },
          {
            "name": "체스트 딥스",
            "set": 4,
            "rep": 10,
            "rest": 90,
            "breath": "내려가며 흡기 / 가슴으로 밀어 올리며 호기",
            "target": "가슴 하부",
            "mind": "가슴을 늘렸다가 폭발적으로 밀어라",
            "tip": "HOW\n1) 상체 15도 숙이기\n2) 3초 하강\n3) 가슴 수축",
            "guide": "POINT\n- 가슴 자극 집중",
            "cue": "가슴으로 밀기"
          },
          {
            "name": "스탠다드 푸쉬업",
            "set": 3,
            "rep": 15,
            "rest": 60,
            "breath": "내려가며 흡기 / 밀며 호기",
            "target": "가슴 전체",
            "mind": "가슴 중앙을 조인다",
            "tip": "HOW\n1) 몸 일직선\n2) 깊게 하강\n3) 상단 수축",
            "guide": "CHECK\n- 엉덩이 처짐 금지",
            "cue": "몸 일직선"
          },
          {
            "name": "덤벨 오버헤드 트라이셉스 익스텐션",
            "set": 3,
            "rep": 10,
            "rest": 60,
            "breath": "올리며 호기",
            "target": "삼두 장두",
            "mind": "팔꿈치 고정",
            "tip": "HOW\n1) 팔꿈치 좁게\n2) 천천히 하강\n3) 삼두 수축",
            "guide": "POINT\n- 삼두 볼륨 핵심",
            "cue": "팔꿈치 고정"
          }
        ]
      },

